{
  "name": "outofoffice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "compile:contracts": "cd contracts/out_of_office && nargo compile",
    "codegen": "aztec codegen contracts/out_of_office/target -o src/artifacts",
    "sandbox": "aztec start --sandbox",
    "deploy:local": "ts-node scripts/deploy.ts",
    "deploy:alpha": "NETWORK=alpha ts-node scripts/deploy.ts"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "puppeteer": "^24.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
